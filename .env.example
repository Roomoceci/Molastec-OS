PORT=3000
# Leave empty locally. In production, use HOST=0.0.0.0 if your platform requires it.
HOST=
NODE_ENV=production

# Primeiro usuario criado quando o banco estiver vazio.
ADMIN_EMAIL=admin@molatech.com
ADMIN_PASSWORD=troque-esta-senha
ADMIN_NAME=Administrador
AUTH_TOKEN_SECRET=troque-por-uma-chave-grande-e-aleatoria

# Use true apenas se quiser criar cliente/tecnico demo em banco novo.
SEED_DEMO_DATA=false

# Use a persistent disk/path in production, for example:
# DB_PATH=/data/molatech.db
DB_PATH=database/molatech.db

# Optional. Use your production URL, for example:
# CORS_ORIGIN=https://seudominio.com.br
CORS_ORIGIN=

# WhatsApp central de atendimento. Use DDI + DDD + número, somente números.
WHATSAPP_CENTRAL_NUMBER=5511999999999
WHATSAPP_CENTRAL_NAME=Central MolaTech

# SMTP para envio automático da NFe/comprovante ao finalizar OS paga.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
